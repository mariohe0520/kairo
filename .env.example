# Kairo AI 剪辑 — 环境变量模板
# 复制此文件为 .env 并填入真实值：
#   cp .env.example .env
#
# ⚠️ .env 已加入 .gitignore，不会被提交到 Git

# ---------------------------------------------------------------------------
# AI 模型 API Keys（至少配置一个以启用 LLM 高光检测）
# ---------------------------------------------------------------------------

# Claude API Key（推荐：高光检测效果最好）
# 申请地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key（备选）
# 申请地址：https://platform.openai.com/
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# 服务器配置（可选，有默认值）
# ---------------------------------------------------------------------------

# 监听端口（默认 8420）
# KAIRO_PORT=8420

# 监听 IP（默认 127.0.0.1 仅本机）
# 改为 0.0.0.0 可允许局域网其他设备访问
# KAIRO_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# 视频处理配置（可选，有默认值）
# ---------------------------------------------------------------------------

# Whisper 模型大小（tiny/base/small/medium/large）
# 越大越准但越慢。base 适合大多数情况
# KAIRO_WHISPER_MODEL=base

# 单次最大上传文件大小（GB）
# KAIRO_MAX_UPLOAD_GB=10

# 同时处理的最大视频数（超出的请求会排队）
# KAIRO_MAX_PIPELINES=2

# pipeline 完成后是否自动删除采样帧（1=是 0=否）
# 建议开启，每小时视频约产生 500MB 帧文件
# KAIRO_CLEANUP_FRAMES=1
